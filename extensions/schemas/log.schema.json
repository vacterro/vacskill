{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VAC LOG Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "timestamp": {
        "type": "string"
      },
      "task_id": {
        "type": "string"
      },
      "type": {
        "type": "string",
        "enum": ["DEC", "RUN", "H"]
      },
      "content": {
        "type": "string",
        "maxLength": 120
      }
    },
    "required": ["timestamp", "type", "content"]
  }
}
