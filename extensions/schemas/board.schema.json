{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SAIPEN BOARD Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "status": {
        "type": "string",
        "enum": ["TODO", "DOING", "DONE", "BLOCKED"],
        "description": "BLOCKED = ticket-level block (RFC § 1.2/VERIFY debug cap), distinct from session-level STATE.phase: BLOCKED"
      },
      "id": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "verify": {
        "type": "string"
      },
      "blocker": {
        "type": "string",
        "description": "Facts + dead ends, set when status is BLOCKED"
      },
      "needs": {
        "type": "array",
        "items": { "type": "string" }
      },
      "owner": {
        "type": "string",
        "description": "Agent ID claiming this ticket"
      },
      "claim_time": {
        "type": "string",
        "format": "date-time"
      }
    },
    "required": ["status", "id", "description"]
  }
}
